         <size>
          <width>200</width>
          <height>50</height>
         </size>
        </property>
        <property name="font">
         <font>
          <pointsize>12</pointsize>
          <bold>true</bold>
         </font>
        </property>
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Start hologram processing.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="styleSheet">
         <string notr="true">QPushButton#ProcessHolograms {
    background-color: #007acc;
    color: #ffffff;
    border: 2px solid #005999;
    border-radius: 8px;
    padding: 10px;
}

QPushButton#ProcessHolograms:hover {
    background-color: #3399ff;
}

QPushButton#ProcessHolograms:pressed {
    background-color: #005999;
}

QPushButton#ProcessHolograms:disabled {
    color: rgba(255,255,255,0.5);
    border-color: rgba(255,255,255,0.3);
}
</string>
        </property>
